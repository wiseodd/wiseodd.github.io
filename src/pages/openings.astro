---
export const prerender = true;

import PageLayout from "../layouts/BaseLayout.astro";
import ContentLayout from "../layouts/ContentLayout.astro";

import { Content as FooterContent } from "../content/openings/footer.md";
import { Content as HeaderContent } from "../content/openings/header.mdx";

import { Content as BScContent } from "../content/openings/bsc.md";
import { Content as DSContent } from "../content/openings/ds.md";
import { Content as MScContent } from "../content/openings/msc.mdx";
import { Content as PhDContent } from "../content/openings/phd.md";
---

<PageLayout meta={{ title: "Openings" }}>
  <ContentLayout>
    <HeaderContent />

    <PhDContent />

    <MScContent />

    <DSContent />

    <BScContent />

    <script>
    const tabs = document.querySelectorAll("[role=\"tab\"]");
    tabs.forEach(tab => {
      tab.addEventListener("click", () => {
        tabs.forEach(t => t.classList.remove("tab-active"));
        document.querySelectorAll("[id^=\"panel-\"]").forEach(p =>
          p.classList.add("hidden")
        );
        tab.classList.add("tab-active");
        document.getElementById(tab.id.replace("tab-", "panel-")).classList
          .remove("hidden");
      });
    });
    </script>

    <FooterContent />
  </ContentLayout>
</PageLayout>
